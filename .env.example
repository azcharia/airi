# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Cerebras API Key for Chat Model (gpt-oss-120b / llama3.1-70b-versatile)
CEREBRAS_API_KEY=your_cerebras_chat_api_key_here

# Cerebras API Key for Memory Extractor Model (llama3.1-8b-instant)
CEREBRAS_EXTRACTOR_API_KEY=your_cerebras_extractor_api_key_here

# Supabase credentials (Long-Term Memory)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# Flask Keep-Alive Port (default: 8080)
FLASK_PORT=8080
